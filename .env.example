# Chat / conversational interface (US-07, US-08)
# Default: Ollama (local open-source LLM) - no API key needed

# --- Ollama (default, local) ---
# Install: https://ollama.ai  then run: ollama pull deepseek-r1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=deepseek-r1:8b

# --- OpenAI (optional) ---
# Uncomment to use ChatGPT instead of local Ollama
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
